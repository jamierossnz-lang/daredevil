SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Reverse proxy / HTTPS (Nginx Proxy Manager, Swag, Traefik, etc.)
# Add your domain so Django accepts CSRF tokens from it.
CSRF_TRUSTED_ORIGINS=https://daredevil.yourdomain.com

# TMDB — https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# qBittorrent Web UI
# When running via Docker Compose, leave these as-is — the compose file overrides
# QBITTORRENT_HOST to the internal service name automatically.
# When connecting to a qBittorrent on another machine, set the IP/hostname here.
QBITTORRENT_HOST=qbittorrent
QBITTORRENT_PORT=8080
QBITTORRENT_USERNAME=admin
QBITTORRENT_PASSWORD=adminadmin

# Redis (overridden by Docker Compose to use the internal redis service)
REDIS_URL=redis://localhost:6379/0

# Default download path
DOWNLOAD_PATH=/media/downloads

# ── Docker-specific ────────────────────────────────────────────────────────
# User/group IDs for LinuxServer containers (run `id` on Linux to find yours)
# Unraid default: PUID=99 PGID=100  (nobody:users)
# macOS/Windows Docker Desktop: 1000 is fine
PUID=1000
PGID=1000

# Timezone — https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Pacific/Auckland

# ── Host paths (bind mounts) ───────────────────────────────────────────────
# All container config and app data lives under DATA_DIR.
# Media directories are mounted separately so they can point at your array.
# Unraid example:
#   DATA_DIR=/mnt/user/appdata/daredevil
#   DOWNLOADS_DIR=/mnt/user/Media/Downloads
#   MOVIES_DIR=/mnt/user/Media/Movies
#   TV_DIR=/mnt/user/Media/TV
DATA_DIR=./data
DOWNLOADS_DIR=./downloads
MOVIES_DIR=./movies
TV_DIR=./tv

# ── Port overrides ─────────────────────────────────────────────────────────
# Unraid WebUI runs on 8080 — change QBT_WEBUI_PORT to avoid the conflict.
APP_PORT=8000
QBT_WEBUI_PORT=8081
JACKETT_PORT=9118

# Plex claim token — get one at https://www.plex.tv/claim/ (expires in 4 minutes)
# Only needed on first run. Remove or leave blank after Plex is set up.
PLEX_CLAIM=

# ── Plex API ───────────────────────────────────────────────────────────────────
# URL of your Plex server (use http://plex:32400 when running via Docker Compose)
PLEX_URL=http://localhost:32400
# Your Plex token — find it at: Plex Web → Account → Authorized Devices → (any device) → token
PLEX_TOKEN=
# Library section names (must match exactly what you named them in Plex)
PLEX_MOVIE_SECTION=Movies
PLEX_TV_SECTION=TV Shows

# ── ntfy push notifications ────────────────────────────────────────────────────
# Install the ntfy app (iOS/Android) or use the web UI at ntfy.sh.
# Pick a unique topic name — anyone who knows it can subscribe, so use something unguessable.
# Self-host ntfy (Docker) for private use; set NTFY_URL to your server and NTFY_TOKEN for auth.
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=                  # e.g. daredevil-abc123   (leave blank to disable)
NTFY_TOKEN=                  # optional: Bearer token for private/authenticated topics
